{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Request Metrics",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list" } },
      "targets": [
        {
          "expr": "rate(supachat_chat_requests_total[5m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Chat Requests / s",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(supachat_chat_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(supachat_chat_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 latency",
          "refId": "B"
        }
      ],
      "title": "Query Latency (p50 / p95)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "System Resources",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=\"supachat-backend\"}[1m])",
          "legendFormat": "Container CPU Usage",
          "refId": "A"
        }
      ],
      "title": "Backend CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=\"supachat-backend\"}",
          "legendFormat": "Container Memory Usage",
          "refId": "A"
        }
      ],
      "title": "Backend Memory Usage",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "title": "Application Logs",
      "type": "row"
    },
    {
      "datasource": "Loki",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=\"supachat-backend\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Backend Logs",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["supachat", "analytics"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "title": "SupaChat Dashboard",
  "uid": "supachat-main",
  "version": 1
}
